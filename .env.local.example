# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # SERVER ONLY — never expose

# ─── Cloudflare Turnstile ─────────────────────────────────────────────────────
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
TURNSTILE_SECRET_KEY=your-turnstile-secret-key    # SERVER ONLY

# ─── Upstash Redis (rate limiting) ───────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# ─── Email notifications (Resend) ────────────────────────────────────────────
RESEND_API_KEY=re_your-resend-api-key              # get one free at resend.com
ADMIN_EMAIL=you@yourcompany.com                   # where lead/expert alerts go

# ─── Admin dashboard ──────────────────────────────────────────────────────────
# Comma-separated list of emails allowed to access /admin
ADMIN_EMAILS=you@yourcompany.com

# ─── Future: AI proxy (server-side only) ─────────────────────────────────────
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
